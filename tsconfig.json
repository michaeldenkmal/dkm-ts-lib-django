{
  "compilerOptions": {
    "target": "es5",
    "module": "commonjs",
    "strict": false,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "inlineSources": true,
    "outDir": "./lib",
    "rootDir": "./src"
  },
  "include": ["src","test"],
  "exclude": ["node_modules"]
}